{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-tauri/main/tooling/cli/schema.json",
  "productName": "Octopal",
  "version": "0.1.19",
  "identifier": "com.studioh.octopal",
  "build": {
    "beforeDevCommand": "npm run dev:renderer",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "vite build --config renderer/vite.config.ts",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Octopal",
        "width": 1200,
        "height": 800,
        "minWidth": 300,
        "minHeight": 400,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https: data:; connect-src 'self' https://api.anthropic.com"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
