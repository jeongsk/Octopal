{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-tauri/main/tooling/cli/schema.json",
  "productName": "Octopal",
  "version": "0.1.42",
  "identifier": "com.studioh.octopal",
  "build": {
    "beforeDevCommand": "npm run dev:renderer",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "vite build --config renderer/vite.config.ts",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Octopal",
        "width": 1200,
        "height": 800,
        "minWidth": 300,
        "minHeight": 400,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost https: data: blob:; connect-src 'self' https://api.anthropic.com https://asset.localhost https://github.com https://objects.githubusercontent.com",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.octopal/**",
          "/tmp/**"
        ]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["octo"],
        "mimeType": "application/json",
        "description": "Octopal Agent File"
      }
    ],
    "externalBin": ["binaries/goose"],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZBODgwQkUxRDNDQkVGOTcKUldTWDc4dlQ0UXVJK2w3bzRHbTcvZ3dTWGdQL1d5dnoxYmVNRFJhVEhUYkljeFpEN1EzR2Joak8K",
      "endpoints": [
        "https://github.com/gilhyun/Octopal/releases/latest/download/latest.json"
      ]
    }
  }
}
