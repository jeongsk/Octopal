{
  "name": "octopal",
  "version": "0.1.0",
  "description": "Chat with your .octo agents. Load a folder, talk to agents in a group room.",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:renderer": "vite --config renderer/vite.config.ts",
    "dev:main": "tsc -p . && unset ELECTRON_RUN_AS_NODE && electron .",
    "build": "tsc -p . && vite build --config renderer/vite.config.ts",
    "start": "unset ELECTRON_RUN_AS_NODE && OCTOPAL_PROD=1 electron .",
    "prod": "npm run build && unset ELECTRON_RUN_AS_NODE && OCTOPAL_PROD=1 electron ."
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.4.11",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "lucide-react": "^1.7.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  }
}
