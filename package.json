{
  "name": "octopal",
  "productName": "Octopal",
  "version": "0.1.13",
  "description": "Chat with your .octo agents. Load a folder, talk to agents in a group room.",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:renderer": "vite --config renderer/vite.config.ts",
    "dev:main": "tsc -p . && cross-env ELECTRON_RUN_AS_NODE= electron .",
    "build": "tsc -p . && vite build --config renderer/vite.config.ts",
    "start": "cross-env ELECTRON_RUN_AS_NODE= OCTOPAL_PROD=1 electron .",
    "prod": "npm run build && cross-env ELECTRON_RUN_AS_NODE= OCTOPAL_PROD=1 electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "node scripts/patch-electron-name.js"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.3"
  },
  "build": {
    "appId": "com.studioh.octopal",
    "productName": "Octopal",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    },
    "linux": {
      "icon": "assets/icon-512.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "i18next": "^26.0.3",
    "lucide-react": "^1.7.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-i18next": "^17.0.2",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  }
}
